@model List<ResultLocationDto>

<section class="services-section pt_120 pb_90">
    <div class="container">
        <div class="section-title centred mb_60">
            <span class="sub-title">Hizmet Bölgeleri</span>
            <h2 class="title">Hizmet Verdiğimiz Öne Çıkan Noktalar</h2>
        </div>
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-xl-3 col-lg-3 col-md-6 col-sm-12">
                    <div class="services-block-one hp-service-card">
                        <h6 class="service-title"><a href="#">@item.LocationName</a></h6>
                        <div class="services-iamge hp-service-image">
                            <img src="@item.LocationImage" alt="">
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<style>
    .hp-service-card {
        height: 100%;
        padding: 22px 22px 0;
        display: flex;
        flex-direction: column;
    }

        .hp-service-card::before {
            inset: 0;
            border-radius: 18px;
            box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
        }

        .hp-service-card .service-title {
            min-height: 52px;
            margin-bottom: 16px;
            display: flex;
            align-items: flex-start;
        }

            .hp-service-card .service-title a {
                width: 100%;
            }

    .hp-service-image {
        margin-top: auto;
        border-radius: 16px;
        overflow: hidden;
        background: #eef2f8;
        aspect-ratio: 4 / 3;
    }

        .hp-service-image img {
            width: 100%;
            height: 100%;
            display: block;
            object-fit: cover;
        }

    .services-section .row > div {
        margin-bottom: 30px;
    }
</style>