@model List<ResultBrandDto>
@{
    var brands = Model ?? new List<ResultBrandDto>();
}

<section class="brand-section pt_120 pb_120">
    <div class="container">
        <div class="section-title-box">
            <div class="section-title">
                <span class="sub-title">Markalar</span>
                <h2 class="title">Premium Araç Markalarını Keşfedin</h2>
            </div>
            <div class="show-all-btn">
                <a href="/Admin/Brand/BrandList" class="btn-style-three">Tüm Markaları Gör</a>
            </div>
        </div>

        <style>
            .hp-brand-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
                gap: 24px;
            }

            .hp-brand-card {
                position: relative;
                min-height: 188px;
                padding: 28px 22px 20px;
                border-radius: 24px;
                background: linear-gradient(180deg, #ffffff 0%, #f6f7fb 100%);
                border: 1px solid rgba(18, 24, 32, 0.08);
                box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
                text-align: center;
                overflow: hidden;
                transition: transform .28s ease, box-shadow .28s ease, border-color .28s ease;
            }

                .hp-brand-card::before {
                    content: "";
                    position: absolute;
                    inset: 0;
                    background: radial-gradient(circle at top right, rgba(215, 255, 76, 0.3), transparent 42%);
                    pointer-events: none;
                }

                .hp-brand-card:hover {
                    transform: translateY(-8px);
                    box-shadow: 0 26px 50px rgba(15, 23, 42, 0.14);
                    border-color: rgba(215, 255, 76, 0.45);
                }

            .hp-brand-logo-wrap {
                position: relative;
                z-index: 1;
                width: 96px;
                height: 96px;
                margin: 0 auto 18px;
                border-radius: 24px;
                background: #fff;
                border: 1px solid rgba(18, 24, 32, 0.08);
                display: flex;
                align-items: center;
                justify-content: center;
                box-shadow: inset 0 1px 0 rgba(255,255,255,.7);
                padding: 16px;
            }

            .hp-brand-logo {
                max-width: 100%;
                max-height: 100%;
                object-fit: contain;
            }

            .hp-brand-fallback {
                font-size: 32px;
                font-weight: 700;
                color: #121820;
                line-height: 1;
            }

            .hp-brand-name {
                position: relative;
                z-index: 1;
                margin-bottom: 8px;
                font-size: 20px;
                font-weight: 700;
                color: #121820;
                line-height: 1.2;
            }

            .hp-brand-status {
                position: relative;
                z-index: 1;
                display: inline-flex;
                align-items: center;
                gap: 8px;
                padding: 8px 14px;
                border-radius: 999px;
                background: rgba(18, 24, 32, 0.05);
                color: #5b6470;
                font-size: 13px;
                font-weight: 600;
            }

            .hp-brand-status-dot {
                width: 9px;
                height: 9px;
                border-radius: 50%;
                background: #28c76f;
                box-shadow: 0 0 0 4px rgba(40, 199, 111, 0.14);
            }

            .hp-brand-card.is-passive .hp-brand-status-dot {
                background: #ff6b6b;
                box-shadow: 0 0 0 4px rgba(255, 107, 107, 0.14);
            }

            .hp-brand-empty {
                padding: 48px 24px;
                border-radius: 24px;
                background: #f6f7fb;
                border: 1px dashed rgba(18, 24, 32, 0.14);
                text-align: center;
                color: #5b6470;
            }
        </style>

        @if (!brands.Any())
        {
            <div class="hp-brand-empty">
                <h5>Henüz marka bulunmuyor</h5>
                <p>Yönetim panelinden marka eklendikten sonra burada görünecektir.</p>
            </div>
        }
        else
        {
            <div class="hp-brand-grid">
                @foreach (var item in brands)
                {
                    var firstLetter = !string.IsNullOrWhiteSpace(item.BrandName)
                    ? item.BrandName.Substring(0, 1).ToUpperInvariant()
                    : "?";

                    <div class="hp-brand-card @(item.Status ? "" : "is-passive")">
                        <div class="hp-brand-logo-wrap">
                            @if (!string.IsNullOrWhiteSpace(item.LogoUrl))
                            {
                                <img src="@item.LogoUrl"
                                     alt="@item.BrandName"
                                     class="hp-brand-logo"
                                     onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
                                <span class="hp-brand-fallback" style="display:none;">@firstLetter</span>
                            }
                            else
                            {
                                <span class="hp-brand-fallback">@firstLetter</span>
                            }
                        </div>

                        <h5 class="hp-brand-name">@item.BrandName</h5>

                        <span class="hp-brand-status">
                            <span class="hp-brand-status-dot"></span>
                            @(item.Status ? "Aktif" : "Pasif")
                        </span>
                    </div>
                }
            </div>
        }
    </div>
</section>