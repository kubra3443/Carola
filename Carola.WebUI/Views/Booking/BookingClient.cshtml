    const dailyPrice = parseLocalizedNumber(dailyPriceInput.value || 0); let selectedFile = null;
    documentFile.addEventListener('change', e => { const file = e.target.files?.[0]; if (!file) return; selectedFile = file; ocrPreviewImage.src = URL.createObjectURL(file); ocrPreview.hidden = false; dropzoneEmpty.hidden = true; ocrStatusText.textContent = 'Belge yuklendi. OCR taramasini baslatabilirsiniz.' });
    ['dragenter', 'dragover'].forEach(n => ocrDropzone.addEventListener(n, e => { e.preventDefault() }));['dragleave', 'drop'].forEach(n => ocrDropzone.addEventListener(n, e => e.preventDefault()));
    ocrDropzone.addEventListener('drop', e => { const file = e.dataTransfer?.files?.[0]; if (!file) return; documentFile.files = e.dataTransfer.files; documentFile.dispatchEvent(new Event('change')) });
    clearButton.addEventListener('click', () => { selectedFile = null; documentFile.value = ''; ocrPreview.hidden = true; dropzoneEmpty.hidden = false; ocrPreviewImage.src = ''; ocrProgressBar.style.width = '0%'; ocrStatusText.textContent = 'OCR baslatildiginda ilerleme burada gosterilir.'; ocrDocType.textContent = 'Belge bekleniyor'; ocrRawText.textContent = ''; ocrRawText.hidden = true; toggleRawText.textContent = 'Goster'; summaryText.textContent = 'Henuz belge taranmadi.';['documentType', 'firstName', 'lastName', 'identityNumber', 'documentNumber', 'birthDate', 'expiryDate', 'licenseClass', 'emailAddress', 'phoneNumber'].forEach(id => $(id).value = '') });
    toggleRawText.addEventListener('click', () => { const hidden = ocrRawText.hidden; ocrRawText.hidden = !hidden; toggleRawText.textContent = hidden ? 'Gizle' : 'Goster' });
    scanButton.addEventListener('click', async () => { if (!selectedFile) { ocrStatusText.textContent = 'Once kimlik veya ehliyet gorseli secin.'; return } try { scanButton.disabled = true; scanButton.textContent = 'Taraniyor...'; ocrProgressBar.style.width = '8%'; ocrStatusText.textContent = 'OCR motoru baslatiliyor...'; const result = await Tesseract.recognize(selectedFile, 'tur+eng', { logger: m => { if (m.status === 'recognizing text' && m.progress) { const p = Math.round(m.progress * 100); ocrProgressBar.style.width = p + '%'; ocrStatusText.textContent = `OCR taraniyor... %${p}` } } }); const rawText = result?.data?.text || ''; ocrRawText.textContent = rawText.trim() || 'Metin bulunamadi.'; const parsed = parseDocument(rawText); applyParsedData(parsed); ocrProgressBar.style.width = '100%'; ocrStatusText.textContent = parsed.summary; ocrDocType.textContent = parsed.documentTypeLabel; summaryText.textContent = parsed.summary } catch (error) { console.error(error); ocrStatusText.textContent = 'OCR sirasinda bir sorun olustu. Daha net bir gorsel ile tekrar deneyin.'; ocrDocType.textContent = 'Tarama basarisiz' } finally { scanButton.disabled = false; scanButton.textContent = 'OCR Tara' } });
    [pickupDate, returnDate].forEach(i => i.addEventListener('change', updateSidebarSummary));
    function formatDate(v) { if (!v) return '-'; const p = v.split('-'); return p.length === 3 ? `${p[2]}.${p[1]}.${p[0]}` : v }
    function formatCurrency(v) { return `${v.toLocaleString('tr-TR', { minimumFractionDigits: 2, maximumFractionDigits: 2 })} TL` }
    function updateSidebarSummary() { sidebarPickupDate.textContent = formatDate(pickupDate.value); sidebarReturnDate.textContent = formatDate(returnDate.value); dailyPriceInput.value = dailyPrice; if (!pickupDate.value || !returnDate.value) { sidebarRentalDays.textContent = '-'; sidebarDayCount.textContent = '0 gun'; sidebarTotalPrice.textContent = formatCurrency(0); totalDayInput.value = 0; totalPriceInput.value = 0; return } const days = Math.max(0, Math.ceil((new Date(returnDate.value) - new Date(pickupDate.value)) / (1000 * 60 * 60 * 24))); sidebarRentalDays.textContent = days > 0 ? `${days} gun` : 'Ayni gun'; sidebarDayCount.textContent = `${days} gun`; sidebarTotalPrice.textContent = formatCurrency(days * dailyPrice); totalDayInput.value = days; totalPriceInput.value = days * dailyPrice }
    function normalizeText(v) { return (v || '').replace(/\r/g, '').replace(/[İI]/g, 'I').replace(/[ı]/g, 'i').replace(/[Ş]/g, 'S').replace(/[ş]/g, 's').replace(/[Ğ]/g, 'G').replace(/[ğ]/g, 'g').replace(/[Ü]/g, 'U').replace(/[ü]/g, 'u').replace(/[Ö]/g, 'O').replace(/[ö]/g, 'o').replace(/[Ç]/g, 'C').replace(/[ç]/g, 'c') }
    function getCleanLines(t) { return t.split('\n').map(l => l.trim()).filter(Boolean) }
    function findFirstMatch(t, r) { const m = t.match(r); return m ? m[1] || m[0] : '' }
    function valueAfterLabel(lines, labels) { const keys = labels.map(l => normalizeText(l).toUpperCase()); for (let i = 0; i < lines.length; i++) { const line = lines[i], norm = normalizeText(line).toUpperCase(); for (const key of keys) { if (norm.includes(key)) { const start = norm.indexOf(key); const tail = line.slice(start + key.length).replace(/^[:\-\s]+/, '').trim(); if (tail) return tail; const next = lines[i + 1]; if (next) return next.trim() } } } return '' }
    function numberedValue(lines, prefixes) { for (const line of lines) { const norm = normalizeText(line).toUpperCase(); for (const prefix of prefixes) { if (norm.startsWith(prefix)) { return line.substring(line.indexOf('.') > -1 ? line.indexOf('.') + 1 : prefix.length).replace(/^[:\-\s]+/, '').trim() } } } return '' }
    function splitFullName(value) { const parts = (value || '').trim().split(/\s+/).filter(Boolean); if (parts.length <= 1) return { firstName: value || '', lastName: '' }; return { firstName: parts.slice(0, -1).join(' '), lastName: parts.slice(-1).join(' ') } }
    function detectDocumentType(rawText) { const n = normalizeText(rawText).toUpperCase(); if (n.includes('SURUCU') || n.includes('DRIVING') || n.includes('DRIVER') || n.includes('SINIF') || n.includes('4D.') || n.includes('BELGE NO')) return 'license'; if (n.includes('KIMLIK') || n.includes('IDENTITY') || n.includes('TURKIYE CUMHURIYETI')) return 'identity'; return 'unknown' }
    function parseDocument(rawText) { const lines = getCleanLines(rawText), type = detectDocumentType(rawText), dates = rawText.match(/\b\d{2}[./-]\d{2}[./-]\d{4}\b/g) || []; const labeledName = valueAfterLabel(lines, ['AD SOYAD', 'ADI SOYADI', 'NAME SURNAME', 'FULL NAME']); const numberedSurname = numberedValue(lines, ['1.', '1 ', '1)']); const numberedName = numberedValue(lines, ['2.', '2 ', '2)']); const nameParts = splitFullName(labeledName); const firstName = numberedName || valueAfterLabel(lines, ['ADI', 'GIVEN NAMES', 'NAME']) || nameParts.firstName; const lastName = numberedSurname || valueAfterLabel(lines, ['SOYADI', 'SURNAME']) || nameParts.lastName; const birthFromLabel = valueAfterLabel(lines, ['DOGUM TARIHI', 'DATE OF BIRTH', '3.']); const expiryFromLabel = valueAfterLabel(lines, ['GECERLILIK', 'VALID UNTIL', '4B.']); const documentNo = valueAfterLabel(lines, ['BELGE NO', 'DOCUMENT NO', 'DOC NO', 'SERI NO', 'SERIAL NO']) || findFirstMatch(rawText, /4d\.\s*([A-Z0-9]+)/i); const licenseClass = valueAfterLabel(lines, ['SINIF', 'CLASS', '9.']) || findFirstMatch(normalizeText(rawText).toUpperCase(), /\b(A1|A2|A|B1|B|BE|C1|C|CE|D1|D|DE|F|G|M)\b/); const parsed = { documentType: type, documentTypeLabel: type === 'identity' ? 'T.C. Kimlik Karti' : type === 'license' ? 'Surucu Belgesi' : 'Belge tipi algilanamadi', firstName: firstName || '', lastName: lastName || '', identityNumber: findFirstMatch(rawText, /\b(\d{11})\b/), documentNumber: documentNo || '', birthDate: birthFromLabel || dates[0] || '', expiryDate: expiryFromLabel || dates[dates.length - 1] || '', licenseClass: licenseClass || '', summary: '' }; const filled = [parsed.firstName, parsed.lastName, parsed.identityNumber, parsed.documentNumber, parsed.birthDate].filter(Boolean).length; parsed.summary = filled > 0 ? `${parsed.documentTypeLabel} algilandi. ${filled} temel alan forma islendi.` : 'Belge okundu ancak alanlar net ayrisamadi. Alanlari manuel kontrol edin.'; return parsed }
    function applyParsedData(p) { $('documentType').value = p.documentTypeLabel || ''; $('firstName').value = p.firstName || ''; $('lastName').value = p.lastName || ''; $('identityNumber').value = p.identityNumber || ''; $('documentNumber').value = p.documentNumber || ''; $('birthDate').value = p.birthDate || ''; $('expiryDate').value = p.expiryDate || ''; $('licenseClass').value = p.licenseClass || '' }
    updateSidebarSummary();
</script>