@model CreateCategoryDto
@{
    ViewData["Title"] = "Kategori Oluştur";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
}

<main id="content">

    <!-- PAGE HEADER -->
    <div class="page-header">
        <div>
            <div class="page-title">Kategori Oluştur</div>
            <div class="page-subtitle">Araç filonuz için yeni bir kategori ve kapak görseli tanımlayın.</div>
        </div>
        <a href="/Category" class="btn-outline">
            <i class="bi bi-arrow-left"></i> Kategorilere Dön
        </a>
    </div>

    <!-- STATS ROW -->
    <div class="row g-3 stats-row">
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-icon yellow"><i class="bi bi-tags"></i></div>
                <div>
                    <div class="stat-value" id="statTotal">0</div>
                    <div class="stat-label">Toplam Kategori</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-icon blue"><i class="bi bi-car-front"></i></div>
                <div>
                    <div class="stat-value" id="statCars">0</div>
                    <div class="stat-label">Toplam Araç</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-icon green"><i class="bi bi-image"></i></div>
                <div>
                    <div class="stat-value" id="statWithImg">0</div>
                    <div class="stat-label">Görselli Kategori</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-icon red"><i class="bi bi-slash-circle"></i></div>
                <div>
                    <div class="stat-value" id="statEmpty">0</div>
                    <div class="stat-label">Boş Kategori</div>
                </div>
            </div>
        </div>
    </div>

    <!-- MAIN LAYOUT -->
    <div class="row g-4">

        <!-- FORM COLUMN -->
        <div class="col-lg-7">
            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-icon"><i class="bi bi-plus-lg"></i></div>
                    <div>
                        <div class="form-card-title">Yeni Kategori</div>
                        <div class="form-card-sub">Aşağıdaki alanları doldurun</div>
                    </div>
                </div>

                <form id="categoryForm"
                      asp-action="CreateCategory"
                      method="post"
                      enctype="multipart/form-data"
                      onsubmit="handleSubmit(event)">
                    @Html.AntiForgeryToken()

                    <!-- Kategori Adı -->
                    <div class="field-group">
                        <label class="field-label" for="CategoryName">
                            Kategori Adı <span class="field-required">*</span>
                        </label>
                        <div class="field-input-wrap">
                            <i class="bi bi-tag field-icon"></i>
                            <input type="text"
                                   id="CategoryName"
                                   name="CategoryName"
                                   class="field-input"
                                   placeholder="ör. Sedan, SUV, Elektrik..."
                                   maxlength="60"
                                   autocomplete="off"
                                   oninput="syncPreview(); validateName(this.value);"
                                   required />
                            <span class="char-count" id="charCount">0 / 60</span>
                        </div>
                        <div class="field-hint">Kategori adı 2 ile 60 karakter arasında olmalıdır.</div>
                        <div class="field-error" id="nameError" style="display:none;"></div>
                    </div>

                    <!-- Kategori Görseli -->
                    <div class="field-group">
                        <label class="field-label">
                            Kategori Görseli <span class="field-required">*</span>
                        </label>

                        <div class="drop-zone" id="dropZone"
                             ondragover="onDragOver(event)"
                             ondragleave="onDragLeave(event)"
                             ondrop="onDrop(event)"
                             onclick="document.getElementById('CategoryImage').click()">

                            <!-- Empty state -->
                            <div class="dz-empty" id="dzEmpty">
                                <div class="dz-icon-wrap">
                                    <i class="bi bi-cloud-arrow-up"></i>
                                </div>
                                <div class="dz-title">Görseli buraya sürükleyin</div>
                                <div class="dz-sub">veya <span class="dz-link">dosya seçin</span></div>
                                <div class="dz-formats">PNG, JPG, WebP &middot; Maks. 5 MB</div>
                            </div>

                            <!-- Preview state -->
                            <div class="dz-preview" id="dzPreview" style="display:none;">
                                <img id="dzPreviewImg" src="" alt="Önizleme" />
                                <div class="dz-overlay">
                                    <button type="button" class="dz-change-btn" onclick="triggerFilePicker(event)">
                                        <i class="bi bi-arrow-repeat"></i> Değiştir
                                    </button>
                                    <button type="button" class="dz-remove-btn" onclick="removeImage(event)">
                                        <i class="bi bi-trash"></i> Kaldır
                                    </button>
                                </div>
                            </div>
                        </div>

                        <input type="file"
                               id="CategoryImage"
                               name="CategoryImageFile"
                               accept="image/png,image/jpeg,image/webp"
                               style="display:none;"
                               onchange="onFileSelected(this)" />
                        <input type="hidden" id="CategoryImageValue" name="CategoryImage" value="" />

                        <div class="field-error" id="imgError" style="display:none;"></div>

                        <!-- Image meta bar -->
                        <div class="img-meta-bar" id="imgMetaBar" style="display:none;">
                            <div class="img-meta-thumb" id="imgMetaThumb"></div>
                            <div class="img-meta-info">
                                <div class="img-meta-name" id="imgMetaName"></div>
                                <div class="img-meta-size" id="imgMetaSize"></div>
                            </div>
                            <div class="img-meta-ok"><i class="bi bi-check-circle-fill"></i></div>
                        </div>
                    </div>

                    <!-- İkon Seç -->
                    <div class="field-group">
                        <label class="field-label">İkon Seç</label>
                        <div class="icon-grid" id="iconGrid"></div>
                        <input type="hidden" name="CategoryIcon" id="CategoryIcon" value="bi-car-front" />
                    </div>

                    <!-- Renk Etiketi -->
                    <div class="field-group">
                        <label class="field-label">Renk Etiketi</label>
                        <div class="color-swatches" id="colorSwatches"></div>
                        <input type="hidden" name="CategoryColor" id="CategoryColor" value="yellow" />
                    </div>

                    <!-- Açıklama -->
                    <div class="field-group">
                        <label class="field-label">
                            Açıklama <span style="color:var(--text-muted);font-weight:400;">(isteğe bağlı)</span>
                        </label>
                        <div class="field-input-wrap">
                            <textarea id="CategoryDesc"
                                      name="CategoryDescription"
                                      class="field-input field-textarea"
                                      placeholder="Kategori hakkında kısa bir açıklama..."
                                      rows="3"
                                      maxlength="200"></textarea>
                        </div>
                    </div>

                    <!-- Actions -->
                    <div class="form-actions">
                        <button type="button" class="btn-outline" onclick="resetForm()">
                            <i class="bi bi-arrow-counterclockwise"></i> Sıfırla
                        </button>
                        <button type="submit" class="btn-accent" id="submitBtn">
                            <i class="bi bi-check-lg"></i> Kategoriyi Kaydet
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- RIGHT COLUMN -->
        <div class="col-lg-5">

            <!-- Live Preview Card -->
            <div class="preview-card">
                <div class="preview-label"><i class="bi bi-eye"></i> Canlı Önizleme</div>

                <!-- Hero Image -->
                <div class="preview-hero" id="previewHero">
                    <div class="preview-hero-empty" id="previewHeroEmpty">
                        <i class="bi bi-image"></i>
                        <span>Görsel yüklenmedi</span>
                    </div>
                    <img id="previewHeroImg" src="" alt="" style="display:none;" />
                    <div class="preview-hero-overlay" id="previewHeroOverlay" style="display:none;">
                        <div class="preview-hero-badge">
                            <div class="preview-hero-icon" id="previewHeroIcon">
                                <i class="bi bi-car-front" id="previewIconEl"></i>
                            </div>
                            <div>
                                <div class="preview-hero-name" id="previewName">Kategori Adı</div>
                                <div class="preview-hero-sub">0 araç</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Badge Preview -->
                <div class="preview-badge-wrap">
                    <div class="preview-badge">
                        <div class="preview-badge-icon stat-icon yellow" id="previewBadgeIcon">
                            <i class="bi bi-car-front" id="previewBadgeIconEl"></i>
                        </div>
                        <div>
                            <div class="preview-badge-name" id="previewBadgeName">Kategori Adı</div>
                            <div class="preview-badge-sub">0 araç</div>
                        </div>
                    </div>
                    <div class="preview-chips">
                        <span class="preview-chip" id="previewChip">Kategori Adı</span>
                        <span class="preview-chip img-chip" id="previewImgChip" style="display:none;">
                            <i class="bi bi-image"></i> Görsel eklendi
                        </span>
                    </div>
                </div>
            </div>

            <!-- Existing Categories -->
            <div class="existing-card">
                <div class="existing-header">
                    <span class="existing-title">Mevcut Kategoriler</span>
                    <span class="existing-count" id="existingCount">0</span>
                </div>
                <div class="existing-list" id="existingList">
                    <div class="existing-empty">
                        <i class="bi bi-tags" style="font-size:28px;color:var(--text-muted);opacity:.4;"></i>
                        <p>Henüz kategori yok.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

</main>

<!-- Toast -->
<div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="liveToast" class="toast align-items-center" role="alert">
        <div class="toast-header">
            <strong class="me-auto" id="toastTitle">Bildirim</strong>
            <button type="button" class="btn-close" data-bs-dismiss="toast"></button>
        </div>
        <div class="toast-body" id="toastMsg"></div>
    </div>
</div>

<!-- ============================================================
     PAGE STYLES
============================================================ -->
<style>
    /* FORM CARD */
    .form-card {
        background: var(--bg-dark2);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 28px;
        animation: fadeUp .35s ease both;
    }

    .form-card-header {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 28px;
        padding-bottom: 20px;
        border-bottom: 1px solid var(--border);
    }

    .form-card-icon {
        width: 44px;
        height: 44px;
        background: var(--accent-dim);
        color: var(--accent);
        border-radius: 12px;
        display: grid;
        place-items: center;
        font-size: 20px;
        flex-shrink: 0;
    }

    .form-card-title {
        font-family: 'Syne', sans-serif;
        font-size: 17px;
        font-weight: 700;
    }

    .form-card-sub {
        font-size: 12px;
        color: var(--text-muted);
        margin-top: 2px;
    }

    /* FIELDS */
    .field-group {
        margin-bottom: 22px;
    }

    .field-label {
        font-size: 13px;
        font-weight: 600;
        color: var(--text-muted);
        display: block;
        margin-bottom: 7px;
    }

    .field-required {
        color: var(--danger);
        margin-left: 3px;
    }

    .field-input-wrap {
        position: relative;
    }

    .field-icon {
        position: absolute;
        left: 13px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        font-size: 15px;
        pointer-events: none;
        transition: color var(--transition);
    }

    .field-input {
        width: 100%;
        background: var(--bg-dark3);
        border: 1px solid var(--border);
        border-radius: 10px;
        color: var(--text);
        padding: 10px 80px 10px 38px;
        font-size: 14px;
        font-family: 'DM Sans', sans-serif;
        outline: none;
        transition: border var(--transition), box-shadow var(--transition);
    }

        .field-input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px var(--accent-dim);
        }

    .field-input-wrap:focus-within .field-icon {
        color: var(--accent);
    }

    .field-input.error {
        border-color: var(--danger) !important;
        box-shadow: 0 0 0 3px rgba(255,82,89,.15) !important;
    }

    .field-input.success {
        border-color: var(--success) !important;
    }

    .field-textarea {
        padding: 10px 14px !important;
        resize: vertical;
        min-height: 80px;
    }

    .char-count {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 11px;
        color: var(--text-muted);
        pointer-events: none;
    }

    .field-hint {
        font-size: 11px;
        color: var(--text-muted);
        margin-top: 5px;
    }

    .field-error {
        font-size: 11px;
        color: var(--danger);
        margin-top: 5px;
    }

    /* DROP ZONE */
    .drop-zone {
        border: 2px dashed var(--border);
        border-radius: var(--radius);
        background: var(--bg-dark3);
        cursor: pointer;
        overflow: hidden;
        transition: border-color var(--transition), background var(--transition), box-shadow var(--transition);
        position: relative;
        min-height: 190px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .drop-zone:hover, .drop-zone.drag-over {
            border-color: var(--accent);
            background: var(--accent-dim);
            box-shadow: 0 0 0 3px var(--accent-dim);
        }

    .dz-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        padding: 36px 20px;
        text-align: center;
        pointer-events: none;
    }

    .dz-icon-wrap {
        width: 56px;
        height: 56px;
        background: var(--bg-dark2);
        border: 1px solid var(--border);
        border-radius: 14px;
        display: grid;
        place-items: center;
        font-size: 26px;
        color: var(--text-muted);
        margin-bottom: 6px;
        transition: border-color var(--transition), color var(--transition);
    }

    .drop-zone:hover .dz-icon-wrap,
    .drop-zone.drag-over .dz-icon-wrap {
        border-color: var(--accent);
        color: var(--accent);
    }

    .dz-title {
        font-size: 14px;
        font-weight: 600;
        color: var(--text);
    }

    .dz-sub {
        font-size: 12px;
        color: var(--text-muted);
    }

    .dz-link {
        color: var(--accent);
        font-weight: 600;
    }

    .dz-formats {
        font-size: 11px;
        color: var(--text-muted);
        margin-top: 4px;
    }

    .dz-preview {
        position: absolute;
        inset: 0;
    }

        .dz-preview img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform .4s ease;
        }

    .drop-zone:hover .dz-preview img {
        transform: scale(1.04);
    }

    .dz-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,.58);
        backdrop-filter: blur(4px);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        opacity: 0;
        transition: opacity var(--transition);
    }

    .drop-zone:hover .dz-overlay {
        opacity: 1;
    }

    .dz-change-btn, .dz-remove-btn {
        border: none;
        border-radius: 9px;
        padding: 9px 16px;
        font-size: 12px;
        font-weight: 600;
        font-family: 'DM Sans', sans-serif;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: opacity var(--transition), transform var(--transition);
    }

    .dz-change-btn {
        background: var(--accent);
        color: var(--bg-dark);
    }

    .dz-remove-btn {
        background: rgba(255,82,89,.92);
        color: #fff;
    }

        .dz-change-btn:hover, .dz-remove-btn:hover {
            opacity: .85;
            transform: translateY(-1px);
        }

    /* Meta bar */
    .img-meta-bar {
        display: flex;
        align-items: center;
        gap: 10px;
        background: rgba(48,224,161,.07);
        border: 1px solid rgba(48,224,161,.2);
        border-radius: 10px;
        padding: 10px 14px;
        margin-top: 10px;
        animation: fadeUp .2s ease both;
    }

    .img-meta-thumb {
        width: 40px;
        height: 40px;
        border-radius: 8px;
        background: var(--bg-dark3);
        overflow: hidden;
        flex-shrink: 0;
    }

        .img-meta-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .img-meta-info {
        flex: 1;
        min-width: 0;
    }

    .img-meta-name {
        font-size: 12px;
        font-weight: 600;
        color: var(--text);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .img-meta-size {
        font-size: 11px;
        color: var(--text-muted);
        margin-top: 1px;
    }

    .img-meta-ok {
        color: var(--success);
        font-size: 20px;
        flex-shrink: 0;
    }

    /* ICON GRID */
    .icon-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .icon-opt {
        width: 42px;
        height: 42px;
        background: var(--bg-dark3);
        border: 1.5px solid var(--border);
        border-radius: 10px;
        display: grid;
        place-items: center;
        font-size: 18px;
        color: var(--text-muted);
        cursor: pointer;
        transition: all var(--transition);
    }

        .icon-opt:hover {
            border-color: rgba(255,255,255,.2);
            color: var(--text);
        }

        .icon-opt.active {
            border-color: var(--accent);
            background: var(--accent-dim);
            color: var(--accent);
        }

    /* COLOR SWATCHES */
    .color-swatches {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .color-swatch {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        cursor: pointer;
        border: 2px solid transparent;
        transition: transform var(--transition), border-color var(--transition);
        position: relative;
    }

        .color-swatch:hover {
            transform: scale(1.15);
        }

        .color-swatch.active {
            border-color: #fff;
            transform: scale(1.15);
        }

            .color-swatch.active::after {
                content: '\F26E';
                font-family: 'bootstrap-icons';
                position: absolute;
                inset: 0;
                display: grid;
                place-items: center;
                font-size: 14px;
                color: #fff;
                text-shadow: 0 1px 3px rgba(0,0,0,.5);
            }

    /* FORM ACTIONS */
    .form-actions {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        padding-top: 20px;
        border-top: 1px solid var(--border);
    }

    /* PREVIEW CARD */
    .preview-card {
        background: var(--bg-dark2);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        margin-bottom: 20px;
        animation: fadeUp .4s .1s ease both;
    }

    .preview-label {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--text-muted);
        font-weight: 600;
        padding: 16px 20px 0;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    /* Hero */
    .preview-hero {
        position: relative;
        height: 200px;
        margin: 14px 16px 0;
        border-radius: 12px;
        overflow: hidden;
        background: var(--bg-dark3);
        border: 1px solid var(--border);
    }

    .preview-hero-empty {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 8px;
        color: var(--text-muted);
        font-size: 12px;
    }

        .preview-hero-empty i {
            font-size: 32px;
            opacity: .35;
        }

    .preview-hero img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .preview-hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(0deg, rgba(0,0,0,.72) 0%, transparent 55%);
        display: flex;
        align-items: flex-end;
        padding: 14px;
    }

    .preview-hero-badge {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .preview-hero-icon {
        width: 40px;
        height: 40px;
        border-radius: 11px;
        display: grid;
        place-items: center;
        font-size: 19px;
        flex-shrink: 0;
        background: rgba(232,255,71,.18);
        color: var(--accent);
        transition: all var(--transition);
    }

    .preview-hero-name {
        font-family: 'Syne', sans-serif;
        font-size: 16px;
        font-weight: 700;
        color: #fff;
    }

    .preview-hero-sub {
        font-size: 11px;
        color: rgba(255,255,255,.55);
        margin-top: 2px;
    }

    .preview-badge-wrap {
        padding: 14px 16px 18px;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .preview-badge {
        display: flex;
        align-items: center;
        gap: 12px;
        background: var(--bg-dark3);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 12px 14px;
    }

    .preview-badge-icon {
        width: 36px;
        height: 36px;
        border-radius: 9px;
        display: grid;
        place-items: center;
        font-size: 17px;
        flex-shrink: 0;
    }

    .preview-badge-name {
        font-family: 'Syne', sans-serif;
        font-size: 14px;
        font-weight: 700;
    }

    .preview-badge-sub {
        font-size: 11px;
        color: var(--text-muted);
        margin-top: 1px;
    }

    .preview-chips {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .preview-chip {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: var(--bg-dark3);
        border: 1px solid var(--border);
        border-radius: 7px;
        padding: 5px 12px;
        font-size: 12px;
        color: var(--text-muted);
    }

    .img-chip {
        color: var(--success) !important;
        border-color: rgba(48,224,161,.25) !important;
        background: rgba(48,224,161,.07) !important;
    }

    /* EXISTING CATEGORIES */
    .existing-card {
        background: var(--bg-dark2);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        animation: fadeUp .45s .15s ease both;
    }

    .existing-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 20px;
        border-bottom: 1px solid var(--border);
    }

    .existing-title {
        font-family: 'Syne', sans-serif;
        font-size: 14px;
        font-weight: 700;
    }

    .existing-count {
        background: var(--accent-dim);
        color: var(--accent);
        font-size: 11px;
        font-weight: 700;
        padding: 3px 9px;
        border-radius: 6px;
    }

    .existing-list {
        padding: 8px;
        max-height: 300px;
        overflow-y: auto;
    }

    .existing-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 8px 10px;
        border-radius: 10px;
        transition: background var(--transition);
        animation: fadeUp .3s ease both;
    }

        .existing-item:hover {
            background: var(--bg-dark3);
        }

    .existing-item-left {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .existing-thumb {
        width: 40px;
        height: 40px;
        border-radius: 9px;
        overflow: hidden;
        flex-shrink: 0;
        background: var(--bg-dark3);
        border: 1px solid var(--border);
        display: grid;
        place-items: center;
        font-size: 16px;
        position: relative;
    }

        .existing-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            position: absolute;
            inset: 0;
        }

    .existing-item-name {
        font-size: 13px;
        font-weight: 600;
    }

    .existing-item-meta {
        font-size: 11px;
        color: var(--text-muted);
        margin-top: 1px;
    }

    .existing-item-del {
        width: 28px;
        height: 28px;
        border: none;
        background: transparent;
        color: var(--text-muted);
        border-radius: 7px;
        display: grid;
        place-items: center;
        cursor: pointer;
        font-size: 13px;
        opacity: 0;
        transition: all var(--transition);
    }

    .existing-item:hover .existing-item-del {
        opacity: 1;
    }

    .existing-item-del:hover {
        background: rgba(255,82,89,.12);
        color: var(--danger);
    }

    .existing-empty {
        text-align: center;
        padding: 32px 20px;
        color: var(--text-muted);
        font-size: 13px;
    }

        .existing-empty p {
            margin-top: 10px;
        }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(16px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes shake {
        0%, 100% {
            transform: translateX(0);
        }

        20%, 60% {
            transform: translateX(-6px);
        }

        40%, 80% {
            transform: translateX(6px);
        }
    }
</style>

@section Scripts {
    <script>
        /* ============================================================
           CONFIG
        ============================================================ */
        const ICONS = [
            'bi-car-front', 'bi-truck', 'bi-bicycle', 'bi-ev-front', 'bi-speedometer2',
            'bi-fuel-pump', 'bi-bus-front', 'bi-taxi-front', 'bi-rocket', 'bi-lightning-charge',
            'bi-star', 'bi-shield-check', 'bi-gem', 'bi-trophy', 'bi-fire'
        ];

        const COLORS = [
            { key: 'yellow', hex: '#e8ff47', dim: 'rgba(232,255,71,.15)' },
            { key: 'blue', hex: '#4f8dff', dim: 'rgba(79,141,255,.15)' },
            { key: 'green', hex: '#30e0a1', dim: 'rgba(48,224,161,.15)' },
            { key: 'red', hex: '#ff5259', dim: 'rgba(255,82,89,.15)' },
            { key: 'purple', hex: '#a855f7', dim: 'rgba(168,85,247,.15)' },
            { key: 'orange', hex: '#ffb547', dim: 'rgba(255,181,71,.15)' },
            { key: 'cyan', hex: '#22d3ee', dim: 'rgba(34,211,238,.15)' },
            { key: 'pink', hex: '#f472b6', dim: 'rgba(244,114,182,.15)' },
        ];

        const MAX_FILE_SIZE = 5 * 1024 * 1024;

        let categories = [];
        let selectedIcon = 'bi-car-front';
        let selectedColor = COLORS[0];
        let currentImgDataUrl = null;
        let hasImage = false;

        /* ============================================================
           INIT
        ============================================================ */
        document.addEventListener('DOMContentLoaded', () => {
            buildIconGrid();
            buildColorSwatches();
            updateStats();
            applyPreviewColor();
        });

        /* ============================================================
           ICON GRID
        ============================================================ */
        function buildIconGrid() {
            document.getElementById('iconGrid').innerHTML = ICONS.map(ic => `
                    <div class="icon-opt ${ic === selectedIcon ? 'active' : ''}"
                         title="${ic}" onclick="selectIcon('${ic}', this)">
                      <i class="bi ${ic}"></i>
                    </div>
                  `).join('');
        }

        function selectIcon(ic, el) {
            document.querySelectorAll('.icon-opt').forEach(e => e.classList.remove('active'));
            el.classList.add('active');
            selectedIcon = ic;
            document.getElementById('CategoryIcon').value = ic;
            document.getElementById('previewIconEl').className = `bi ${ic}`;
            document.getElementById('previewBadgeIconEl').className = `bi ${ic}`;
        }

        /* ============================================================
           COLOR SWATCHES
        ============================================================ */
        function buildColorSwatches() {
            document.getElementById('colorSwatches').innerHTML = COLORS.map((c, i) => `
                    <div class="color-swatch ${i === 0 ? 'active' : ''}"
                         style="background:${c.hex};" title="${c.key}"
                         onclick="selectColor('${c.key}', this)"></div>
                  `).join('');
        }

        function selectColor(key, el) {
            document.querySelectorAll('.color-swatch').forEach(e => e.classList.remove('active'));
            el.classList.add('active');
            selectedColor = COLORS.find(c => c.key === key);
            document.getElementById('CategoryColor').value = key;
            applyPreviewColor();
        }

        function applyPreviewColor() {
            const els = [
                document.getElementById('previewHeroIcon'),
                document.getElementById('previewBadgeIcon')
            ];
            els.forEach(el => {
                if (!el) return;
                el.style.background = selectedColor.dim;
                el.style.color = selectedColor.hex;
            });
        }

        /* ============================================================
           DROP ZONE
        ============================================================ */
        function onDragOver(e) {
            e.preventDefault();
            document.getElementById('dropZone').classList.add('drag-over');
        }
        function onDragLeave() {
            document.getElementById('dropZone').classList.remove('drag-over');
        }
        function onDrop(e) {
            e.preventDefault();
            document.getElementById('dropZone').classList.remove('drag-over');
            const file = e.dataTransfer.files[0];
            if (file) processFile(file);
        }
        function triggerFilePicker(e) {
            e.stopPropagation();
            document.getElementById('CategoryImage').click();
        }
        function onFileSelected(input) {
            if (input.files[0]) processFile(input.files[0]);
        }

        function processFile(file) {
            const imgError = document.getElementById('imgError');

            if (!['image/png', 'image/jpeg', 'image/webp'].includes(file.type)) {
                showImgError('Yalnızca PNG, JPG veya WebP dosyaları kabul edilir.');
                return;
            }
            if (file.size > MAX_FILE_SIZE) {
                showImgError(`Dosya boyutu ${(file.size / 1024 / 1024).toFixed(1)} MB — maksimum 5 MB olmalıdır.`);
                return;
            }
            imgError.style.display = 'none';

            const reader = new FileReader();
            reader.onload = (ev) => {
                currentImgDataUrl = ev.target.result;
                hasImage = true;
                document.getElementById('CategoryImageValue').value = currentImgDataUrl;

                // Drop zone
                document.getElementById('dzEmpty').style.display = 'none';
                document.getElementById('dzPreview').style.display = '';
                document.getElementById('dzPreviewImg').src = currentImgDataUrl;

                // Meta bar
                document.getElementById('imgMetaBar').style.display = '';
                document.getElementById('imgMetaThumb').innerHTML = `<img src="${currentImgDataUrl}" alt="" />`;
                document.getElementById('imgMetaName').textContent = file.name;
                document.getElementById('imgMetaSize').textContent = formatBytes(file.size);

                // Hero preview
                document.getElementById('previewHeroEmpty').style.display = 'none';
                document.getElementById('previewHeroImg').style.display = '';
                document.getElementById('previewHeroImg').src = currentImgDataUrl;
                document.getElementById('previewHeroOverlay').style.display = '';

                // Chip
                document.getElementById('previewImgChip').style.display = '';
                syncPreview();
            };
            reader.readAsDataURL(file);
        }

        function removeImage(e) {
            if (e && e.stopPropagation) e.stopPropagation();
            currentImgDataUrl = null;
            hasImage = false;

            document.getElementById('CategoryImage').value = '';
            document.getElementById('CategoryImageValue').value = '';
            document.getElementById('dzPreview').style.display = 'none';
            document.getElementById('dzEmpty').style.display = '';
            document.getElementById('imgMetaBar').style.display = 'none';

            document.getElementById('previewHeroEmpty').style.display = '';
            document.getElementById('previewHeroImg').style.display = 'none';
            document.getElementById('previewHeroImg').src = '';
            document.getElementById('previewHeroOverlay').style.display = 'none';
            document.getElementById('previewImgChip').style.display = 'none';
            document.getElementById('imgError').style.display = 'none';
        }

        function showImgError(msg) {
            const el = document.getElementById('imgError');
            el.textContent = msg;
            el.style.display = 'block';
            const dz = document.getElementById('dropZone');
            dz.style.animation = 'none';
            requestAnimationFrame(() => { dz.style.animation = 'shake .32s ease'; });
        }

        /* ============================================================
           LIVE PREVIEW
        ============================================================ */
        function syncPreview() {
            const val = document.getElementById('CategoryName').value;
            const name = val.trim() || 'Kategori Adı';
            document.getElementById('charCount').textContent = `${val.length} / 60`;
            document.getElementById('previewName').textContent = name;
            document.getElementById('previewBadgeName').textContent = name;
            document.getElementById('previewChip').textContent = name;
            applyPreviewColor();
        }

        /* ============================================================
           VALIDATION
        ============================================================ */
        function validateName(val) {
            const input = document.getElementById('CategoryName');
            const errEl = document.getElementById('nameError');
            const trimmed = val.trim();

            if (!trimmed) { setFieldState(input, errEl, null); return false; }
            if (trimmed.length < 2) { setFieldState(input, errEl, 'En az 2 karakter olmalıdır.', 'error'); return false; }

            const dup = categories.some(c => c.name.toLowerCase() === trimmed.toLowerCase());
            if (dup) { setFieldState(input, errEl, 'Bu isimde bir kategori zaten mevcut.', 'error'); return false; }

            setFieldState(input, errEl, null, 'success');
            return true;
        }

        function setFieldState(input, errEl, msg, state) {
            input.classList.remove('error', 'success');
            errEl.style.display = 'none';
            if (state === 'error') { input.classList.add('error'); errEl.textContent = msg; errEl.style.display = 'block'; }
            if (state === 'success') { input.classList.add('success'); }
        }

        /* ============================================================
           SUBMIT
        ============================================================ */
        function handleSubmit(e) {
            const nameVal = document.getElementById('CategoryName').value;
            if (!validateName(nameVal)) {
                e.preventDefault();
                return;
            }
        }

        /* ============================================================
           RESET
        ============================================================ */
        function resetForm() {
            document.getElementById('CategoryName').value = '';
            document.getElementById('CategoryDesc').value = '';
            document.getElementById('charCount').textContent = '0 / 60';

            const input = document.getElementById('CategoryName');
            input.classList.remove('error', 'success');
            document.getElementById('nameError').style.display = 'none';

            removeImage(null);

            selectedIcon = 'bi-car-front';
            selectedColor = COLORS[0];
            buildIconGrid();
            buildColorSwatches();

            document.getElementById('previewIconEl').className = 'bi bi-car-front';
            document.getElementById('previewBadgeIconEl').className = 'bi bi-car-front';
            document.getElementById('previewName').textContent = 'Kategori Adı';
            document.getElementById('previewBadgeName').textContent = 'Kategori Adı';
            document.getElementById('previewChip').textContent = 'Kategori Adı';
            applyPreviewColor();
        }

        /* ============================================================
           EXISTING LIST
        ============================================================ */
        function addToExistingList(cat) {
            categories.push(cat);
            renderExistingList();
            updateStats();
        }

        function renderExistingList() {
            const list = document.getElementById('existingList');
            document.getElementById('existingCount').textContent = categories.length;

            if (!categories.length) {
                list.innerHTML = `
                      <div class="existing-empty">
                        <i class="bi bi-tags" style="font-size:28px;color:var(--text-muted);opacity:.4;"></i>
                        <p>Henüz kategori yok.</p>
                      </div>`;
                return;
            }

            list.innerHTML = categories.map(c => `
                    <div class="existing-item" id="ecat-${c.id}">
                      <div class="existing-item-left">
                        <div class="existing-thumb" style="color:${c.color.hex};">
                          ${c.imgUrl
                    ? `<img src="${c.imgUrl}" alt="" /><i class="bi ${c.icon}" style="opacity:.3;"></i>`
                    : `<i class="bi ${c.icon}"></i>`}
                        </div>
                        <div>
                          <div class="existing-item-name">${escHtml(c.name)}</div>
                          <div class="existing-item-meta">
                            ${c.cars} araç
                            ${c.imgUrl
                    ? '&nbsp;·&nbsp;<span style="color:var(--success);"><i class="bi bi-image"></i> Görsel</span>'
                    : '<span style="color:var(--text-muted);opacity:.6;">&nbsp;·&nbsp;Görselsiz</span>'}
                          </div>
                        </div>
                      </div>
                      <button class="existing-item-del" onclick="deleteCategory(${c.id})" title="Sil">
                        <i class="bi bi-trash"></i>
                      </button>
                    </div>
                  `).join('');
        }

        function deleteCategory(id) {
            const el = document.getElementById('ecat-' + id);
            if (!el) return;
            el.style.transition = 'opacity .25s, transform .25s';
            el.style.opacity = '0';
            el.style.transform = 'translateX(12px)';
            setTimeout(() => {
                categories.splice(categories.findIndex(c => c.id === id), 1);
                renderExistingList();
                updateStats();
                showToast('Kategori silindi.', 'danger');
            }, 260);
        }

        /* ============================================================
           STATS
        ============================================================ */
        function updateStats() {
            document.getElementById('statTotal').textContent = categories.length;
            document.getElementById('statCars').textContent = categories.reduce((s, c) => s + c.cars, 0);
            document.getElementById('statWithImg').textContent = categories.filter(c => c.imgUrl).length;
            document.getElementById('statEmpty').textContent = categories.filter(c => c.cars === 0).length;
        }

        /* ============================================================
           TOAST
        ============================================================ */
        function showToast(msg, type = 'success') {
            const colors = { success: 'var(--success)', danger: 'var(--danger)', info: 'var(--accent2)' };
            const el = document.getElementById('liveToast');
            document.getElementById('toastMsg').textContent = msg;
            document.getElementById('toastTitle').style.color = colors[type] || colors.success;
            new bootstrap.Toast(el, { delay: 3000 }).show();
        }

        /* ============================================================
           HELPERS
        ============================================================ */
        function formatBytes(b) {
            if (b < 1024) return b + ' B';
            if (b < 1048576) return (b / 1024).toFixed(1) + ' KB';
            return (b / 1048576).toFixed(2) + ' MB';
        }

        function escHtml(str) {
            return String(str).replace(/[&<>"']/g,
                m => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[m])
            );
        }
    </script>
}